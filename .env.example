# ── Base de datos — Supabase (recomendado para producción) ──────────────────
#
# En Supabase Dashboard → Settings → Database → Connection string
#
# DATABASE_URL → Transaction Pooler  (puerto 6543)
#   Úsalo en Vercel. El pooler reutiliza conexiones entre funciones serverless.
#   Añade ?pgbouncer=true para que Prisma desactive los prepared statements.
#
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# DIRECT_URL → Conexión directa   (puerto 5432)
#   Solo se usa para migraciones (prisma db push / prisma migrate deploy).
#   NO pongas pgbouncer=true aquí.
#
DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require"

# NextAuth — genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="secreto-aleatorio-min-32-caracteres"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# Resend (emails transaccionales) — obtén tu API key en resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="TQ-HELP <noreply@tudominio.com>"

# Vercel Blob — se autoconfigura automáticamente en Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# URL pública de la app (para links en emails)
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"

# ──────────────────────────────────────────────────────────────────────────
# Observabilidad
# ──────────────────────────────────────────────────────────────────────────

# Sentry — error tracking y performance.
# Crear proyecto en https://sentry.io → Settings → Client Keys (DSN).
# Ambos son iguales; el NEXT_PUBLIC_ expone al bundle cliente.
SENTRY_DSN="https://xxxxx@oXXX.ingest.sentry.io/XXXX"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@oXXX.ingest.sentry.io/XXXX"

# Sampling (0.0–1.0). 1.0 = 100%. Bajar en producción si hay mucho tráfico.
SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.1

# Para subir source maps durante el build (opcional — sólo en CI/Vercel).
SENTRY_ORG="tu-org"
SENTRY_PROJECT="tq-help"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxx"

# BetterStack Logs (Logtail) — fuente con token "Source token".
# Crear en https://logs.betterstack.com → Sources → Connect source → HTTP.
LOGTAIL_SOURCE_TOKEN="xxxxxxxxxxxxxxxxxxxx"
# Opcional: endpoint personalizado (Vector/Logtail on-prem).
# LOGTAIL_INGESTING_HOST="https://in.logs.betterstack.com"

# Umami Cloud — analytics sin cookies (GDPR).
# Crear website en https://cloud.umami.is → copiar Website ID.
NEXT_PUBLIC_UMAMI_WEBSITE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# Opcional: restringir tracking a dominios concretos (CSV).
# NEXT_PUBLIC_UMAMI_DOMAINS="tq-help.empresa.com"
# Opcional: script alternativo (por defecto cloud.umami.is/script.js).
# NEXT_PUBLIC_UMAMI_SRC="https://cloud.umami.is/script.js"
