# Base de datos PostgreSQL (Neon, Supabase, Vercel Postgres...)
DATABASE_URL="postgresql://user:password@host:5432/tqhelp?sslmode=require"

# NextAuth — genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="secreto-aleatorio-min-32-caracteres"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# Resend (emails transaccionales) — obtén tu API key en resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="TQ-HELP <noreply@tudominio.com>"

# Vercel Blob — se autoconfigura automáticamente en Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# URL pública de la app (para links en emails)
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"
